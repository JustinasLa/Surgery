    }

    class SurgeryMenuManager {
        -JavaPlugin plugin
        -SurgeryItemsConfig itemsConfig
        -ItemAPI api
        -DiagnosisChecker diagnosisChecker
        -SurgeryStateManager stateManager
        -SurgeryUIUpdater uiUpdater
        -SurgeryMenuBuilder menuBuilder
