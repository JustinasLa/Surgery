        +updateStatusBlock(menu: Inventory, playerId: UUID) void
        +getMessage(key: String) String
        +getMessageList(key: String) List~String~
    }

    class SurgeryMenuBuilder {
        -JavaPlugin plugin
        -ItemAPI api
        -SurgeryStateManager stateManager
        -SurgeryUIUpdater uiUpdater
